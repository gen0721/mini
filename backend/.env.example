PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/minions
JWT_SECRET=your-super-secret-jwt-key-change-this

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=YourMinionBot
ADMIN_TELEGRAM_ID=your-telegram-id

# Admin panel
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-this-password

# App URL
APP_URL=https://your-app.railway.app

# Payments
RUKASSA_SHOP_ID=your-rukassa-shop-id
RUKASSA_SECRET=your-rukassa-secret-key
CRYPTOCLOUD_API_KEY=your-cryptocloud-api-key
CRYPTOCLOUD_SHOP_ID=your-cryptocloud-shop-id
CRYPTO_BOT_TOKEN=your-crypto-bot-token

# Commission
COMMISSION_PERCENT=5
